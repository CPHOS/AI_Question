# ===== LLM 服务商配置 =====
# 支持: openrouter | openai_compatible
LLM_PROVIDER=openrouter

# ===== OpenRouter（默认）=====
OPENROUTER_API_KEY=sk-or-...

# ===== 通用 OpenAI 兼容 API（DeepSeek、本地部署等）=====
# 使用时将 LLM_PROVIDER 改为 openai_compatible 并填写以下变量
# LLM_API_KEY=sk-xxx
# LLM_BASE_URL=https://api.deepseek.com/v1

# ===== 大模型（命题 / 验算 / 仲裁）=====
BIG_MODEL_NAME=google/gemini-2.5-pro-preview

# ===== 小模型（仅格式化排版，不接触数学公式）=====
SMALL_MODEL_NAME=openai/gpt-4o-mini
