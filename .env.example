# ===== OpenRouter API =====
# 所有模型通过 OpenRouter 统一调用
OPENROUTER_API_KEY=sk-or-...

# ===== 大模型（命题 / 验算 / 仲裁）=====
BIG_MODEL_NAME=google/gemini-2.5-pro-preview

# ===== 小模型（仅格式化排版，不接触数学公式）=====
SMALL_MODEL_NAME=openai/gpt-4o-mini

# ===== DeepSeek 替代方案（取消注释即可切换）=====
